{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASH Task Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "tasks"],
  "properties": {
    "schema_version": {"type": "string"},
    "branch": {"type": "string"},
    "execution_loop": {"type": "array", "items": {"type": "string"}},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "status"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"enum": ["complete", "blocked", "deferred", "open"]},
          "required_paths": {"type": "array", "items": {"type": "string"}},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
