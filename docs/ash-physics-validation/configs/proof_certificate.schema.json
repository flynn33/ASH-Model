{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASH Computational Proof Certificate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "certificate_schema",
    "project_version",
    "arithmetic",
    "sections",
    "checks",
    "all_checks_pass",
    "source_sha256"
  ],
  "properties": {
    "certificate_schema": {
      "type": "string"
    },
    "project_version": {
      "type": "string"
    },
    "arithmetic": {
      "type": "string"
    },
    "sections": {
      "type": "object",
      "required": [
        "code",
        "decoder",
        "hypercube",
        "projection",
        "adinkra",
        "branching",
        "markov_chain",
        "physics",
        "empirical_bridge",
        "prediction_ledger",
        "standard_baseline"
      ],
      "additionalProperties": {
        "type": "object"
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "all_checks_pass": {
      "type": "boolean"
    },
    "source_sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    }
  }
}
