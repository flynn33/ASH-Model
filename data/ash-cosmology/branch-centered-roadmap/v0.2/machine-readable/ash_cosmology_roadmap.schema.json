      "type": "string"
    },
    "package_version": {
      "type": "string"
    },
    "locked_principle": {
      "type": "string"
    },
    "corrected_cosmology_formula": {
      "type": "string"
    },
    "primary_object": {
      "type": "object"
    },
    "model_layers": {
      "type": "array"
    },
    "many_worlds_options": {
      "type": "object"
    },
    "one_line_roadmap": {
      "type": "string"
    }
  }
}
